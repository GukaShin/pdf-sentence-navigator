{
  "name": "pdf-sentence-navigator",
  "version": "0.1.0",
  "description": "Chrome MV3 extension for keyboard sentence navigation in PDFs, powered by a local PDF.js viewer.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "test:pdf": "node scripts/generate-test-pdf.mjs"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38"
  }
}
